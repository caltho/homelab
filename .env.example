# Copy to .env and edit. .env is gitignored (it holds secrets).

# Timezone for all containers
TZ=Etc/UTC

# Base domain for Caddy vhosts -> ha.<DOMAIN>, plex.<DOMAIN>
DOMAIN=home.lan
# Email used for Let's Encrypt if you switch Caddy to public TLS
ACME_EMAIL=you@example.com

# Host user/group that owns config + media (id callum -> 1000)
PUID=1000
PGID=1000
# 'render' group id — grants Plex access to /dev/dri for Quick Sync
RENDER_GID=993

# Where all container config + media lives
DATA_ROOT=/home/callum/docker/data

# Optional: claim token from https://plex.tv/claim (valid ~4 min) for first-run
PLEX_CLAIM=

# Samba credentials for the media share
SAMBA_USER=callum
SAMBA_PASS=changeme
